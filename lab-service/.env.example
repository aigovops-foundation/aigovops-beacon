# AIGovOps Beacon — Lab Service environment template
# Copy to .env for local dev. Do NOT commit your real .env file.

# Admin password (used to log in to the admin panel on first boot).
# Once the server has bootstrapped, the password is stored hashed in data.db
# and this env var is only used as the initial value. Rotate from the UI.
ADMIN_PASSWORD=change-me

# Display name shown to trainees on the login screen.
LAB_NAME=AIGovOps Beacon Lab

# Optional. Defaults to 5000.
PORT=5000
