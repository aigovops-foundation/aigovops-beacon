# beacon-v2 CLI — local overrides (copy to .beacon-v2.env; never commit)
# Every variable here is optional; the CLI has sane defaults.

# Repo + identity
GH_OWNER=bobrapp
GH_REPO=aigovops-beacon
GH_DEFAULT_BRANCH=main

# Fly backend layer
FLY_APP=aigovops-beacon-lab
FLY_REGION=sea
FLY_PRIMARY_HOSTNAME=api.beacon-lab.aigovops.foundation

# Cloudflare edge layer
CF_WORKER_NAME=aigovops-beacon-edge
CF_WORKER_HOSTNAME=edge.beacon.aigovops.foundation

# pplx.app fallback layer (current host)
PPLX_APP_SLUG=aigovops-beacon-lab
PPLX_SITE_ID=2138e2e2-b04a-4283-a6f9-aa507069fd41
PPLX_ASSET_ID=8e301e3b-5e4c-48a0-94bd-8dfe27828598

# Pages v2 flag layer
PAGES_FLAG_FILE=docs/lab.html
PAGES_FLAG_DEFAULT_ON=true   # when on, sets window.__BEACON_V2_DEFAULT__ = true

# Cron / sync workflow
SYNC_WORKFLOW_FILE=.github/workflows/sync-from-backend.yml

# Runtime secrets the backend layer expects (read via flyctl secrets set)
# ADMIN_PASSWORD=change-me
# JWT_PRIVATE_KEY_PEM=...
# JWT_PUBLIC_KEY_PEM=...
# CORS_ALLOWED_ORIGINS=https://bobrapp.github.io,https://edge.beacon.aigovops.foundation
