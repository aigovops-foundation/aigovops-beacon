# Beacon server environment. Copy to .env and edit for your deployment.

BEACON_HOST=127.0.0.1
BEACON_PORT=8787

# Where Beacon stores its database, keys, receipts, and bundles.
# Default is ~/.beacon — override here for containers.
# BEACON_DATA_DIR=/var/lib/beacon

# Capture mode for prompts and results.
#   hash_only   — never store prompt/result text. Smallest footprint, safest.
#   redacted    — store hashes; configure redactors for known PII.
#   full        — store everything. Only with explicit legal sign-off.
BEACON_CAPTURE_MODE=redacted

# Default environment label applied to discovery events from this host.
BEACON_ENV=production
