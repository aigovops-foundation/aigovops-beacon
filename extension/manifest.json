{
  "manifest_version": 3,
  "name": "AiGovOps Beacon",
  "short_name": "Beacon",
  "version": "2.2.0",
  "description": "Verifiable AI governance — emits signed, hostname-only receipts to Beacon. Apache-2.0.",
  "minimum_chrome_version": "114",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": [],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AiGovOps Beacon",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "storage": {
    "managed_schema": "managed_schema.json"
  }
}
