# Copy to .env and fill before `docker compose -f deploy/beta.yml up -d`.

BEACON_PUBLIC_URL=https://beacon.corp.example.com

# OIDC (Okta / Entra / Auth0 / Google)
OIDC_ISSUER_URL=https://YOUR-TENANT.okta.com/oauth2/default
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# 32 random bytes, base64url. Generate: openssl rand -base64 32 | tr -- '+/' '-_'
OIDC_COOKIE_SECRET=

# DNS log tail — point at the file or directory your corp resolver writes to.
DNS_LOG_PATH=/var/log/named

# CASB API (Netskope / Zscaler / Defender for Cloud Apps)
CASB_API_BASE=https://api.YOUR-CASB.example.com/v1
CASB_API_KEY=
